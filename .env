# Khalti Payment Gateway — public key is safe to expose in the browser
# Official Khalti demo public key — works with the test wallet below
VITE_KHALTI_PUBLIC_KEY=test_public_key_dc74e0fd57cb46cd93832aee0a390234

# Set to true to bypass the Khalti widget during local development
# The backend must also have KHALTI_TEST=true for this to work end-to-end
VITE_KHALTI_TEST=true

# Google Maps API Key (get from Google Cloud Console)
# To get API key:
# 1. Go to https://console.cloud.google.com/
# 2. Create a new project or select existing one
# 3. Enable "Maps JavaScript API" and "Places API"
# 4. Create credentials -> API Key
# 5. Replace YOUR_GOOGLE_MAPS_API_KEY below with your actual key
VITE_GOOGLE_MAPS_API_KEY=AIzaSyB41DRUbKWJHPxaFjMAwdrzWzbVKartNGg

